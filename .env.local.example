# Get these from your Sentry project: Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/your-project-id

# Get from: sentry.io → Settings → Auth Tokens
SENTRY_AUTH_TOKEN=your-auth-token-here

# Your Sentry org slug (from the URL: sentry.io/organizations/YOUR-ORG/)
SENTRY_ORG=your-org-slug

# Your Sentry project slug
SENTRY_PROJECT=your-project-slug

# App version for release tracking
NEXT_PUBLIC_APP_VERSION=v1.0.0-demo
